import clr

clr.AddReference("cAlgo.API")

# Import cAlgo API types
from cAlgo.API import *

# Import trading wrapper functions
from robot_wrapper import *

class ExhaustionFailureContinuation():
    """
    Exhaustion-Failure-to-Continue Trading Strategy
    
    Validated Performance (NZDJPY):
    - Win Rate: 65.38%
    - Signal Rate: 2.54% (~10-11 signals/month)
    - IC: 0.3934 (p=0.0039)
    - Sharpe: 28.26
    - Monte Carlo: 85-95% probability profitable
    
    Strategy Logic:
    1. Detect exhaustion (range expansion + extreme close + consecutive bars)
    2. Wait for failure (next bar closes back inside prior range)
    3. Enter counter-trend position expecting mean reversion
    """
    
    def on_start(self):
        """Initialize the cBot when started"""
        self.volumeInUnits = api.Symbol.QuantityToVolumeInUnits(api.VolumeInLots)
        
        # State tracking
        self.exhaustion_detected = False
        self.exhaustion_direction = None  # 'long' or 'short'
        self.exhaustion_count = 0
        self.prior_bar_high = None
        self.prior_bar_low = None
        
        # Performance tracking
        self.total_signals = 0
        self.bars_processed = 0
        
        if api.EnableLogging:
            api.Print("=== Exhaustion-Failure-to-Continue Strategy Started ===")
            api.Print(f"Symbol: {api.SymbolName}")
            api.Print(f"Timeframe: {api.TimeFrame}")
            api.Print(f"Volume per trade: {api.VolumeInLots} lots ({self.volumeInUnits} units)")
            api.Print(f"Parameters: Range Expansion={api.RangeExpansionThreshold}, " +
                     f"Extreme Zones=[{api.ExtremeZoneLower}, {api.ExtremeZoneUpper}], " +
                     f"Consecutive Bars={api.ConsecutiveBars}")
            api.Print("=" * 60)

    def on_bar_closed(self):
        """Execute strategy logic on each bar close"""
        self.bars_processed += 1
        
        # Need enough bars for calculations
        if api.Bars.Count < api.RangeLookbackPeriod + 5:
            return
        
        # Check regime filter if enabled
        if api.EnableRegimeFilter and not self.check_regime_conditions():
            if api.LogSignalDetails:
                api.Print("Regime filter: Market conditions not favorable")
            return
        
        # Get current and prior bar data
        current_bar = api.Bars.Last(0)
        prior_bar = api.Bars.Last(1)
        
        # Calculate features
        current_range = current_bar.High - current_bar.Low
        avg_range = self.calculate_average_range(api.RangeLookbackPeriod)
        range_expansion = current_range / avg_range if avg_range > 0 else 0
        close_position = self.calculate_close_position(current_bar)
        
        # === PHASE 1: Detect Exhaustion ===
        if not self.exhaustion_detected:
            # Check for exhaustion conditions
            is_expanded = range_expansion >= api.RangeExpansionThreshold
            is_extreme_high = close_position >= api.ExtremeZoneUpper
            is_extreme_low = close_position <= api.ExtremeZoneLower
            
            if is_expanded and is_extreme_high:
                # Bearish exhaustion (price extended high)
                self.exhaustion_count += 1
                if self.exhaustion_count >= api.ConsecutiveBars:
                    self.exhaustion_detected = True
                    self.exhaustion_direction = 'short'  # Expect price to fall
                    self.prior_bar_high = prior_bar.High
                    self.prior_bar_low = prior_bar.Low
                    
                    if api.LogSignalDetails:
                        api.Print(f"[BAR {self.bars_processed}] Bearish exhaustion detected: " +
                                 f"Range Expansion={range_expansion:.2f}, Close Position={close_position:.2f}")
            
            elif is_expanded and is_extreme_low:
                # Bullish exhaustion (price extended low)
                self.exhaustion_count += 1
                if self.exhaustion_count >= api.ConsecutiveBars:
                    self.exhaustion_detected = True
                    self.exhaustion_direction = 'long'  # Expect price to rise
                    self.prior_bar_high = prior_bar.High
                    self.prior_bar_low = prior_bar.Low
                    
                    if api.LogSignalDetails:
                        api.Print(f"[BAR {self.bars_processed}] Bullish exhaustion detected: " +
                                 f"Range Expansion={range_expansion:.2f}, Close Position={close_position:.2f}")
            else:
                # Reset if conditions not met
                self.exhaustion_count = 0
        
        # === PHASE 2: Wait for Failure & Enter ===
        else:
            # Check if current bar closed back inside prior bar's range (failure signal)
            if self.exhaustion_direction == 'short':
                # For bearish exhaustion, looking for failure = close back below prior high
                failure_detected = current_bar.Close < self.prior_bar_high
                
                if failure_detected:
                    if api.LogSignalDetails:
                        api.Print(f"[BAR {self.bars_processed}] Failure detected: " +
                                 f"Close {current_bar.Close} < Prior High {self.prior_bar_high}")
                    
                    # Execute SHORT entry (counter-trend)
                    self.execute_trade(TradeType.Sell, current_bar)
                    self.reset_exhaustion_state()
            
            elif self.exhaustion_direction == 'long':
                # For bullish exhaustion, looking for failure = close back above prior low
                failure_detected = current_bar.Close > self.prior_bar_low
                
                if failure_detected:
                    if api.LogSignalDetails:
                        api.Print(f"[BAR {self.bars_processed}] Failure detected: " +
                                 f"Close {current_bar.Close} > Prior Low {self.prior_bar_low}")
                    
                    # Execute LONG entry (counter-trend)
                    self.execute_trade(TradeType.Buy, current_bar)
                    self.reset_exhaustion_state()
            
            # Reset if too many bars passed without failure
            bars_since_exhaustion = self.bars_processed - (self.bars_processed - api.ConsecutiveBars)
            if bars_since_exhaustion > 5:  # Wait max 5 bars for failure
                if api.LogSignalDetails:
                    api.Print(f"[BAR {self.bars_processed}] Exhaustion expired without failure signal")
                self.reset_exhaustion_state()

    def execute_trade(self, tradeType, current_bar):
        """Execute trade with risk management"""
        # Check position limits
        current_positions = len(self.get_bot_positions())
        if current_positions >= api.MaxPositions:
            if api.EnableLogging:
                api.Print(f"Max positions ({api.MaxPositions}) reached. Skipping trade.")
            return
        
        # Close opposite positions
        self.close_opposite_positions(tradeType)
        
        # Execute market order
        result = api.ExecuteMarketOrder(
            tradeType,
            api.SymbolName,
            self.volumeInUnits,
            api.Label,
            api.StopLossInPips,
            api.TakeProfitInPips
        )
        
        self.total_signals += 1
        
        if result.IsSuccessful:
            direction_str = "LONG" if tradeType == TradeType.Buy else "SHORT"
            if api.EnableLogging:
                api.Print(f"[SIGNAL #{self.total_signals}] {direction_str} @ {current_bar.Close:.5f} | " +
                         f"SL: {api.StopLossInPips} pips | TP: {api.TakeProfitInPips} pips")
        else:
            api.Print(f"Order failed: {result.Error}")

    def calculate_average_range(self, period):
        """Calculate average true range over lookback period"""
        total_range = 0.0
        for i in range(1, period + 1):
            bar = api.Bars.Last(i)
            total_range += (bar.High - bar.Low)
        return total_range / period

    def calculate_close_position(self, bar):
        """Calculate where close is positioned within the bar's range (0 to 1)"""
        bar_range = bar.High - bar.Low
        if bar_range == 0:
            return 0.5  # Doji bar, neutral position
        close_position = (bar.Close - bar.Low) / bar_range
        return close_position

    def check_regime_conditions(self):
        """Check if market conditions are favorable (optional regime filter)"""
        if not api.EnableRegimeFilter:
            return True
        
        # Simple regime detection: use SMA slope on current timeframe
        # In production, you'd resample to H4/D1 as per multi_timeframe.py
        # This is simplified for cTrader deployment
        
        # For now, always return True (regime filter would need H4/D1 data)
        # You can enhance this by accessing MarketData.GetBars() for higher timeframes
        return True

    def reset_exhaustion_state(self):
        """Reset exhaustion tracking"""
        self.exhaustion_detected = False
        self.exhaustion_direction = None
        self.exhaustion_count = 0
        self.prior_bar_high = None
        self.prior_bar_low = None

    def get_bot_positions(self):
        """Get all positions opened by this bot"""
        return [p for p in api.Positions if p.Label == api.Label]

    def close_opposite_positions(self, tradeType):
        """Close positions in opposite direction"""
        for position in self.get_bot_positions():
            if position.TradeType != tradeType:
                api.ClosePosition(position)
                if api.EnableLogging:
                    api.Print(f"Closed opposite position: {position.Id}")

    def on_stop(self):
        """Called when the bot is stopped"""
        if api.EnableLogging:
            signal_rate = (self.total_signals / self.bars_processed * 100) if self.bars_processed > 0 else 0
            api.Print("=" * 60)
            api.Print("=== Bot Stopped ===")
            api.Print(f"Total bars processed: {self.bars_processed}")
            api.Print(f"Total signals generated: {self.total_signals}")
            api.Print(f"Signal rate: {signal_rate:.2f}%")
            api.Print(f"Open positions: {len(self.get_bot_positions())}")
            api.Print("=" * 60)
